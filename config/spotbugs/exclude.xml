<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclude filter for SatSim.

  Intentionally empty: no findings are excluded by default. Every future
  exclusion added here must, at minimum, name the bug pattern, the class
  (or method) it applies to, and a written justification for why the
  finding is a false positive or an accepted risk - and must be added via
  a reviewed PR, not ad hoc.
-->
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">
</FindBugsFilter>
